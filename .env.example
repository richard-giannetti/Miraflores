# Casa (Miraflores) PMS — environment configuration
# Copy to .env and adjust for your environment.

# PostgreSQL connection string. Postgres is REQUIRED (not SQLite) because the
# reservation non-overlap guarantee relies on a GiST exclusion constraint.
DATABASE_URL="postgresql://casa:casa@localhost:5432/casa?schema=public"

# Secret used to sign staff session cookies and guest check-in tokens.
# Generate with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL, used to build guest check-in links.
APP_URL="http://localhost:3000"

# Encryption key (base64, 32 bytes) for guest ID images at rest.
# Generate with: openssl rand -base64 32
ID_ENCRYPTION_KEY="change-me-32-byte-base64-key"
